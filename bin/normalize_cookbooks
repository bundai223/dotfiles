#!/usr/bin/env perl
use utf8;
use strict;
use warnings;

my @raw_cookbooks = @ARGV;

if (!@raw_cookbooks) {
  print STDERR "need cookbooks!\n";
  exit 1;
}

# 解決したcookbookパスはまとめてから一度に出力する。
# エラーはSTDERRに出し、STDOUTには成功時のパスのみを流す
# （bin/deployがSTDOUTをmitamaeの引数として使うため、エラー文を混ぜない）。
my @resolved;
foreach my $raw (@raw_cookbooks) {
  if (-f "$raw") {
    push @resolved, $raw;
  } elsif (-f "$raw.rb") {
    push @resolved, "$raw.rb";
  } elsif (-f "$raw/default.rb") {
    push @resolved, "$raw/default.rb";
  } else {
    print STDERR "please check cookbook name. : ${raw}\n";
    exit 1;
  }
}

print join(' ', @resolved), "\n";
