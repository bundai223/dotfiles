#!/bin/bash
# Homebrew does not allow sudo.

# set -x #debug
set -eu

./bin/setup

mitamae() {
  cookbooks=$@
  cmd="bin/mitamae local --shell /bin/bash -l debug lib/recipe_helper.rb $cookbooks"
  case "$(uname)" in
    "Darwin")  bin/mitamae local -l debug lib/recipe_helper.rb $cookbooks ;;
    # *) $cmd ;;
    # *) sudo -i bash -c "cd $(pwd) && $cmd" ;; # -iつけてるとcurrent-context is not setと表示される
    *) sudo bash -c "cd $(pwd) && $cmd" ;;
  esac
}

if [ "$#" = "0" ]; then
  mitamae lib/recipe.rb
else
  # cookbook名の解決に失敗したら（typo等）、エラー文を引数として渡さずここで止める
  cookbooks=$(./bin/normalize_cookbooks "$@") || exit 1
  mitamae $cookbooks
fi
