#.zshenv
BREW_PATH=`/opt/homebrew/bin/brew --prefix`

# for FBX path setting
FBXSDK_ROOT=/Applications/Autodesk/FBX\ SDK/2013.3/

# path setting
export EDITOR=nvimalter
# export EDITOR=/Applications/MacVim.app/Contents/MacOS/Vim
export SHELL=${BREW_PATH}/bin/zsh

# for homebrew
PATH=$HOME/.nodebrew/current/bin:$PATH
PATH=${BREW_PATH}/bin:$PATH
PATH=~/.cabal/bin:$PATH
PATH=~/tools/bin:$PATH
#for android
PATH=${ANDROID_HOME}/tools:$PATH
PATH=${ANDROID_HOME}/platform-tools:$PATH

export GOROOT=${BREW_PATH}/opt/go/libexec
export GOPATH=~/go
## go lang
if [ "$GOROOT" != "" ]; then
    PATH=$GOROOT/bin:$GOPATH/bin:$PATH
fi

PATH=~/.cargo/bin:$PATH

#export LDFLAGS=-L/usr/local/opt/qt5/lib
#export CPPFLAGS=-I/usr/local/opt/qt5/include
export PATH
